FROM apache/airflow:2.9.1-python3.11

USER root

RUN apt-get update --allow-releaseinfo-change || true \
    && apt-get install -y --no-install-recommends \
        libnss3 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_BROWSERS_PATH=/opt/airflow/pw-browsers
RUN mkdir -p /opt/airflow/pw-browsers && chown -R airflow: /opt/airflow/pw-browsers

USER airflow

RUN pip install --no-cache-dir \
    playwright==1.44.0 \
    snowflake-connector-python==3.10.1 \
    dbt-snowflake==1.8.0 \
    dbt-core==1.8.0 \
    pandas==2.2.2 \
    pyarrow==14.0.2 \
    python-dotenv==1.0.1 \
    "apache-airflow-providers-snowflake>=5.0.0"

RUN playwright install chromium

USER root
RUN /home/airflow/.local/bin/playwright install-deps chromium

USER airflow